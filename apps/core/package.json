{
  "name": "@copilot-swarm/core",
  "version": "0.0.67",
  "description": "Multi-agent orchestrator for GitHub Copilot — coordinates PM, designer, engineer, reviewer, and tester agents through a declarative pipeline",
  "license": "MIT",
  "type": "module",
  "bin": {
    "swarm": "dist/index.js"
  },
  "files": [
    "dist",
    "defaults",
    "scripts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://cpswarm.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/urbanisierung/copilot-swarm.git",
    "directory": "apps/core"
  },
  "bugs": {
    "url": "https://github.com/urbanisierung/copilot-swarm/issues"
  },
  "keywords": [
    "copilot",
    "github-copilot",
    "ai",
    "agents",
    "multi-agent",
    "orchestrator",
    "swarm",
    "pipeline",
    "code-generation",
    "copilot-sdk",
    "ai-agents",
    "developer-tools",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "check": "biome check src/",
    "test": "vitest run",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@github/copilot-sdk": "latest",
    "yaml": "^2.8.2"
  }
}
