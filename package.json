{
  "name": "copilot-swarm",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "check": "turbo run check",
    "test": "turbo run test",
    "verify": "turbo run build typecheck check test",
    "demo": "npx tsx apps/core/scripts/demo-tui.ts",
    "demo:fleet": "npx tsx apps/core/scripts/demo-fleet.ts",
    "demo:intro": "npx tsx apps/core/scripts/demo-intro.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "global": "turbo run build --filter=@copilot-swarm/core && cd apps/core && pnpm pack && npm install -g copilot-swarm-core-*.tgz && rm copilot-swarm-core-*.tgz"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^2.3.15",
    "@changesets/cli": "^2.29.8",
    "@types/node": "latest",
    "tsx": "latest",
    "turbo": "^2.8.8",
    "typescript": "latest",
    "vitest": "^4.0.18"
  }
}
